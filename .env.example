# ServeIQ — environment variables
# Copy this file to `.env.local` and fill in your real values.
# `.env.local` is gitignored; never commit real keys.

# Anthropic API key used by src/app/api/respond/route.ts to generate AI replies.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-key-here
